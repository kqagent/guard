@id("GRANT-WRITABLE-PATHS")
permit (
  principal,
  action == Aegis::Action::"write_path",
  resource
)
when { context.path == "src" || context.path like "src/*" ||
       context.path == "scratch" || context.path like "scratch/*" ||
       context.path == "tmp" || context.path like "tmp/*" };

// --- rbac (per-principal tool authorization) ---

@id("RBAC-reporting-bot-Bash")
permit (
  principal == Aegis::Agent::"reporting-bot",
  action == Aegis::Action::"use_tool",
  resource == Aegis::Tool::"Bash"
);

@id("RBAC-reporting-bot-Read")
permit (
  principal == Aegis::Agent::"reporting-bot",
  action == Aegis::Action::"use_tool",
  resource == Aegis::Tool::"Read"
);

